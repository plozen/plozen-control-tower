# Public-safe placeholders only.
# Copy this file to .env.local for local development.

PLOZEN_OPS_CONSOLE_ENV=local
KNOWLEDGE_API_BASE_URL=http://localhost:8100
NEXT_PUBLIC_APP_NAME="PLOZEN Ops Console"

# Ops Console live data collector.
# local: read the OS where the Next server runs.
# ssh: read a target host over SSH. Keep host/user/key details in .env.local or deployment env.
OPS_CONSOLE_COLLECTOR=local
OPS_CONSOLE_SERVER_LABEL="현재 서버"
OPS_CONSOLE_SSH_HOST=
OPS_CONSOLE_DATA_PATHS=/mnt/data,/data,/srv,/home
